# HomeGallery - Configuration Example
# Copy this file to .env and edit as needed
# Note: data/config.json takes precedence over .env

# Database (use config.json setup wizard for first-time config)
# DATABASE_URL=sqlite:///./data/gallery.db
# DATABASE_URL=postgresql://user:password@localhost:5432/homegallery

# Server
# PORT=8080
# HOST=0.0.0.0

# Security (auto-generated by setup wizard)
# SECRET_KEY=your-secret-key-here
# JWT_EXPIRE_MINUTES=1440

# Directories (set via setup wizard)
# PHOTO_DIR=./data/photos
# THUMBNAIL_DIR=./data/thumbnails
# FACE_ENCODING_DIR=./data/face_encodings
